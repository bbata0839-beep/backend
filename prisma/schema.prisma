generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]
  companies Company[]
  contacts  Contact[]
  deals     Deal[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Char(36)
  tenantId     String   @map("tenant_id") @db.Char(36)
  fullName     String   @map("full_name") @db.VarChar(120)
  email        String   @unique @db.VarChar(180)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role     @default(user)
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Company {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @map("tenant_id") @db.Char(36)
  name      String   @db.VarChar(180)
  createdBy String   @map("created_by") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("companies")
}

model Contact {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @map("tenant_id") @db.Char(36)
  name      String   @db.VarChar(160)
  createdBy String   @map("created_by") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model Deal {
  id        String    @id @default(uuid()) @db.Char(36)
  tenantId  String    @map("tenant_id") @db.Char(36)
  title     String    @db.VarChar(220)
  amount    Decimal   @default(0.0) @db.Decimal(14, 2)
  stage     DealStage @default(prospect)
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("deals")
}

enum Role {
  owner
  admin
  sales
  staff
  user
}

enum DealStage {
  prospect
  qualified
  proposal
  won
  lost
}